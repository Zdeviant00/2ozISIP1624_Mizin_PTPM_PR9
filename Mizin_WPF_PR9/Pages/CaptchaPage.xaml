<Page x:Class="Mizin_WPF_PR9.Pages.CaptchaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CAPTCHA" Height="400" Width="400"
      Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Введите CAPTCHA" 
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10"/>

        <!-- Изображение CAPTCHA с шумом -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" 
                Background="#F0F0F0" Margin="10" Height="80">
            <Image x:Name="CaptchaImage" Stretch="Uniform"/>
        </Border>

        <TextBox Grid.Row="2" x:Name="TextBoxCaptcha" 
                 Margin="10" Height="30" FontSize="14"
                 HorizontalContentAlignment="Center"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="10">
            <Button Content="Проверить" Width="100" Height="35" 
                    Click="ButtonVerify_Click" Margin="5"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="Обновить" Width="100" Height="35" 
                    Click="ButtonRefresh_Click" Margin="5"
                    Background="#2196F3" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="TextBlockError" 
                   Foreground="Red" TextWrapping="Wrap" 
                   TextAlignment="Center" Margin="10" Visibility="Collapsed"/>
    </Grid>
</Page>