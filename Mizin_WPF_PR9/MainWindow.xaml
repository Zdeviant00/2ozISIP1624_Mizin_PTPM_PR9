<Window x:Class="Mizin_WPF_PR9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа №9" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопка "Назад" -->
        <Button Grid.Row="0" Content="Назад" Width="100" Height="30" 
                HorizontalAlignment="Left" Margin="10" 
                Click="ButtonBack_Click"/>

        <!-- Frame с указанием страницы авторизации через Source -->
        <Frame Grid.Row="1" x:Name="MainFrame" NavigationUIVisibility="Hidden" 
               Source="/Pages/AuthPage.xaml"/>
    </Grid>
</Window>