<Page x:Class="Mizin_WPF_PR9.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Mizin_WPF_PR9.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация"
      Background="White">
    <!-- Белый фон страницы -->

    <Grid Background="White">
        <!-- Белый фон Grid -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Логин с плейсхолдером -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" 
                   VerticalAlignment="Center" Margin="10" FontSize="14"/>
        <Grid Grid.Row="0" Grid.Column="1" Margin="10">
            <TextBox x:Name="TextBoxLogin" Height="30" FontSize="14"
                     TextChanged="TextBoxLogin_TextChanged">
            </TextBox>
            <TextBlock x:Name="WatermarkLogin" Text="Введите логин" 
                       Foreground="Gray" FontSize="14"
                       VerticalAlignment="Center" Margin="5,0"
                       IsHitTestVisible="False"
                       Visibility="Visible"/>
        </Grid>

        <!-- Пароль с плейсхолдером -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:" 
                   VerticalAlignment="Center" Margin="10" FontSize="14"/>
        <Grid Grid.Row="1" Grid.Column="1" Margin="10">
            <PasswordBox x:Name="PasswordBox" Height="30" FontSize="14"
                         PasswordChanged="PasswordBox_PasswordChanged">
            </PasswordBox>
            <TextBlock x:Name="WatermarkPassword" Text="Введите пароль" 
                       Foreground="Gray" FontSize="14"
                       VerticalAlignment="Center" Margin="5,0"
                       IsHitTestVisible="False"
                       Visibility="Visible"/>
        </Grid>

        <!-- Кнопка Вход -->
        <Button Grid.Row="2" Grid.Column="1" Content="Вход" 
                Margin="10" Height="35" FontSize="14" 
                Click="ButtonLogin_Click" Background="#4CAF50" Foreground="White"/>

        <!-- Кнопка Регистрация -->
        <Button Grid.Row="3" Grid.Column="1" Content="Регистрация" 
                Margin="10" Height="35" FontSize="14" 
                Click="ButtonRegister_Click" Background="#2196F3" Foreground="White"/>

        <!-- Сообщение об ошибке -->
        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                   x:Name="TextBlockError" Foreground="Red" 
                   Margin="10" TextWrapping="Wrap" Visibility="Collapsed"/>
    </Grid>
</Page>