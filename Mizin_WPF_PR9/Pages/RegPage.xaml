<Page x:Class="Mizin_WPF_PR9.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация" Height="450" Width="800"
      Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ФИО -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО:" 
                   VerticalAlignment="Center" Margin="10" FontSize="14"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TextBoxFIO" 
                 Margin="10" Height="30" FontSize="14"/>

        <!-- Логин -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Логин:" 
                   VerticalAlignment="Center" Margin="10" FontSize="14"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TextBoxLogin" 
                 Margin="10" Height="30" FontSize="14"/>

        <!-- Пароль -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Пароль:" 
                   VerticalAlignment="Center" Margin="10" FontSize="14"/>
        <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="PasswordBox" 
                     Margin="10" Height="30" FontSize="14"/>

        <!-- Подтверждение пароля -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Подтверждение пароля:" 
                   VerticalAlignment="Center" Margin="10" FontSize="14"/>
        <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="PasswordBoxConfirm" 
                     Margin="10" Height="30" FontSize="14"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Регистрация" Width="120" Height="35" 
                    Click="ButtonRegister_Click" Margin="5"
                    Background="#4CAF50" Foreground="White" FontSize="14"/>
            <Button Content="Отмена" Width="120" Height="35" 
                    Click="ButtonCancel_Click" Margin="5"
                    Background="#f44336" Foreground="White" FontSize="14"/>
        </StackPanel>

        <!-- Сообщение об ошибке -->
        <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                   x:Name="TextBlockError" Foreground="Red" 
                   Margin="10" TextWrapping="Wrap" Visibility="Collapsed"
                   TextAlignment="Center"/>
    </Grid>
</Page>